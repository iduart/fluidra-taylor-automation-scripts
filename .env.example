# Copy this file to `.env` in the same folder and fill in real values.
# `.env` is gitignored — never commit it.

# Epicor OData (Basic auth + X-API-Key)
EPICOR_BASE_URL=
EPICOR_COMPANY=
EPICOR_USERNAME=
EPICOR_PASSWORD=
EPICOR_API_KEY=

# Shopify Admin API (GraphQL)
# Store name is the subdomain only (e.g. `my-store` from my-store.myshopify.com)
SHOPIFY_STORE_NAME=
SHOPIFY_ACCESS_TOKEN=
# Optional; defaults to 2026-01 in code if unset
# SHOPIFY_API_VERSION=2026-01

# Optional — product sync only: pin inventory location (GID) or leave unset
# SHOPIFY_LOCATION_ID=

# Optional tuning (defaults shown in script headers)
# EPICOR_PAGE_SIZE=200
# EPICOR_TIMEOUT_MS=60000
# SHOPIFY_TIMEOUT_MS=60000
# EPICOR_MAIN_WAREHOUSE_CODE=MAIN
